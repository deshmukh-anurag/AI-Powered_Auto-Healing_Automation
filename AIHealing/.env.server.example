# ============================================================================
# Server Environment Variables (Copy to .env.server and add your real keys)
# ============================================================================

# ----------------------------------------------------------------------------
# Gemini API Configuration (FREE for University Projects!)
# ----------------------------------------------------------------------------
# Get your free API key at: https://aistudio.google.com/app/apikey
# No credit card required. 1,500 free requests per day.
GEMINI_API_KEY=AIzaSyC_your_actual_key_here

# ----------------------------------------------------------------------------
# Database Configuration (Optional - Wasp handles this automatically)
# ----------------------------------------------------------------------------
# DATABASE_URL is auto-configured by Wasp, but you can override it here
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ----------------------------------------------------------------------------
# ChromaDB Configuration (Vector Database for RAG)
# ----------------------------------------------------------------------------
# Default: http://localhost:8000
# Change this if you're running ChromaDB on a different host/port
CHROMA_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Optional: OpenAI API Key (NOT NEEDED - We use free Gemini!)
# ----------------------------------------------------------------------------
# Only add this if you want to use OpenAI embeddings instead of local ones
# OPENAI_API_KEY=sk-...
